# =============================================================================
# Docker Build Context Exclusions (.dockerignore)
# =============================================================================
# 
# This file specifies which files and directories should be excluded from the
# Docker build context. Excluding unnecessary files reduces build context size,
# speeds up builds, and prevents sensitive files from being copied to the image.
#
# For more information: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# =============================================================================

# -----------------------------------------------------------------------------
# Version Control and CI/CD
# -----------------------------------------------------------------------------
# Git repository and GitHub-specific files are not needed in the container
.git
.gitignore
.gitattributes
.github

# -----------------------------------------------------------------------------
# LaTeX Auxiliary Files
# -----------------------------------------------------------------------------
# Temporary files generated during LaTeX compilation
# These will be regenerated in the container, no need to copy them
*.aux
*.lof
*.log
*.lot
*.fls
*.out
*.toc
*.fmt
*.fot
*.cb
*.cb2
*.bbl
*.blg
*.bcf
*.brf
*.idx
*.ilg
*.ind
*.glo
*.gls
*.ist
*.acr
*.alg
*.nav
*.snm
*.synctex.gz
*.fdb_latexmk
*.run.xml
*.auxlock

# -----------------------------------------------------------------------------
# Build Output Folders
# -----------------------------------------------------------------------------
# Generated build artifacts
build/
out/
dist/

# -----------------------------------------------------------------------------
# Editor and OS-specific Files
# -----------------------------------------------------------------------------
# These vary by development environment and are not needed for builds
.DS_Store          # macOS Finder metadata
Thumbs.db          # Windows thumbnail cache
.vscode/           # VS Code settings
.idea/             # JetBrains IDE settings
*.iml              # IntelliJ module files
*.swp              # Vim swap files

# TeXstudio editor-specific files
*.txs-profile
*.txs-undo

# -----------------------------------------------------------------------------
# Python Build Artifacts
# -----------------------------------------------------------------------------
# Python bytecode and cache files from scripts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# -----------------------------------------------------------------------------
# Archive and Documentation Directories
# -----------------------------------------------------------------------------
# Historical and reference materials not needed for PDF generation
archive/           # Branch history and analysis
legacy/            # Deprecated/archived code
review/            # Code review materials

# Documentation files (needed for repo but not for Docker builds)
*.md
DISCLAIMER.txt
LICENSE
SECURITY.md
CONTRIBUTING.md
CHANGELOG.md

# -----------------------------------------------------------------------------
# Utility Scripts and Configuration
# -----------------------------------------------------------------------------
# Scripts not required for the PDF generation process
cleanup/           # LaTeX cleanup scripts (for local dev only)
task_skripts/      # Task-specific helper scripts
branch_cleanup     # Branch management utilities

# -----------------------------------------------------------------------------
# Configuration Files
# -----------------------------------------------------------------------------
# Editor and linting configurations
.editorconfig
cspell.json

# -----------------------------------------------------------------------------
# Additional Content Directories
# -----------------------------------------------------------------------------
wiki/              # Wiki documentation (published separately)
Besprechung/       # Meeting notes (not part of PDFs)

# -----------------------------------------------------------------------------
# Note: Files Required for Docker Build
# -----------------------------------------------------------------------------
# The following are intentionally NOT excluded as they're needed:
# - Ausarbeitung/ (LaTeX source for written work)
# - Vortrag/ (LaTeX source for presentation)
# - scripts/generatePdf.sh (PDF generation script)
# - Dockerfile and related build files
# =============================================================================
