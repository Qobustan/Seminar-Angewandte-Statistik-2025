      "pattern": "```[\\s\\S]*?```"
    },
    {
      "name": "latex-inline-math",
      "pattern": "\\$[^$]+\\$"
    },
    {
      "name": "latex-display-math",
      "pattern": "\\$\\$[\\s\\S]*?\\$\\$"
    }
